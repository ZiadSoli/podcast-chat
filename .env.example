LISTENNOTES_API_KEY=your_listennotes_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
PORT=3000

# ── Auth ──────────────────────────────────────────────────────────────────────
# Random secret for signing session cookies (generate with: openssl rand -hex 32)
SESSION_SECRET=change_me_to_a_random_secret

# Public base URL used to build magic links — no trailing slash
# Local dev: http://localhost:3000
# Production: https://your-app.up.railway.app
BASE_URL=http://localhost:3000

# ── Email (Resend SMTP) ───────────────────────────────────────────────────────
# Get your API key at https://resend.com
# If omitted, magic links are printed to the server console (dev mode)
RESEND_API_KEY=re_your_api_key_here

# The From address shown in emails — must be a verified domain in Resend
EMAIL_FROM=noreply@yourdomain.com
